# =============================================================================
# Binance API — Mainnet (Spot + FAPI Futures)
# =============================================================================
BINANCE_API_KEY=your_mainnet_api_key_here
BINANCE_API_SECRET=your_mainnet_api_secret_here

# Base URLs (leave defaults unless routing through proxy)
BINANCE_BASE_URL=https://api.binance.com
BINANCE_FAPI_BASE_URL=https://fapi.binance.com

# =============================================================================
# Binance Demo Futures — Paper Trading (FAPI Testnet)
# Register at: https://testnet.binancefuture.com → "Get API Key" button
# Keys here are separate from mainnet keys, generated on the testnet site
# =============================================================================
BINANCE_DEMO_API_KEY=your_demo_futures_api_key_here
BINANCE_DEMO_API_SECRET=your_demo_futures_api_secret_here
BINANCE_DEMO_FAPI_BASE_URL=https://testnet.binancefuture.com

# Set to "true" to route all FAPI order execution to demo instead of mainnet
BINANCE_USE_DEMO=false

# =============================================================================
# Data Sources (used only for initial data download, not during training)
# =============================================================================
# CoinMetrics — on-chain data (NVT, SOPR, exchange_flow)
COINMETRICS_API_KEY=your_coinmetrics_api_key_here

# Alternative.me Fear & Greed Index (free, no key required by default)
# FEAR_GREED_API_URL=https://api.alternative.me/fng/

# =============================================================================
# Telegram Notifications
# How to setup:
#   1. Message @BotFather on Telegram → /newbot → copy the token
#   2. Start a chat with your bot, then open:
#      https://api.telegram.org/bot<TOKEN>/getUpdates
#      and copy your chat_id from the response
# =============================================================================
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here
